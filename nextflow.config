// GCP Batch configuration for GPU testing
process {
    executor = 'google-batch'

    withName: GPU_TEST {
        machineType = 'n1-standard-4'
        accelerator = [request: 1, type: 'nvidia-tesla-t4']
    }
}

google {
    project = 'tower-cloud-testing'
    location = 'us-central1'
    batch {
        spot = false
    }
}

workDir = 'gs://scidev-testing-central/esha/gpus'
